# Agent Toolkit — .gitignore

# 对话 artifacts（每次会话的临时产物，不纳入版本管理）
antigravity/brain/

# 浏览器 profile（包含本地浏览器数据）
antigravity-browser-profile/

# 浏览器录屏（二进制数据，非常大）
antigravity/browser_recordings/

# 本地设置（可能包含敏感配置）
settings.json

# 旧备份文件
GEMINI - 副本.txt

# 技能描述的临时翻译文件
antigravity/skills/desc_list.json
antigravity/skills/desc_translated.json

# 系统运行缓存与会话数据 (Protobuf histories, states, etc)
antigravity/conversations/
antigravity/annotations/
antigravity/implicit/
antigravity/code_tracker/
antigravity/context_state/
antigravity/html_artifacts/
antigravity/playground/
antigravity/prompting/
antigravity/knowledge/
_versions/
